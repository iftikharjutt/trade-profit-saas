// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionTier {
  FREE
  PRO
  PREMIUM
}

enum PositionSide {
  LONG
  SHORT
}

enum PositionStatus {
  OPEN
  CLOSED
}

model User {
  id                     Int              @id @default(autoincrement())
  name                   String
  email                  String           @unique
  password_hash          String
  subscription_tier      SubscriptionTier @default(FREE)
  stripe_customer_id     String?          @unique
  stripe_subscription_id String?          @unique
  
  portfolios             Portfolio[]
  positions              Position[]
  
  created_at             DateTime         @default(now())
  updated_at             DateTime         @updatedAt
}

model Portfolio {
  id          Int        @id @default(autoincrement())
  user_id     Int
  user        User       @relation(fields: [user_id], references: [id])
  name        String
  currency    String     @default("USD")
  positions   Position[]
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt

  @@index([user_id])
}

model Position {
  id            Int            @id @default(autoincrement())
  user_id       Int
  user          User           @relation(fields: [user_id], references: [id])
  portfolio_id  Int?
  portfolio     Portfolio?     @relation(fields: [portfolio_id], references: [id])
  
  asset_symbol  String         // e.g., "BTC/USDT"
  side          PositionSide
  status        PositionStatus @default(OPEN)
  
  leverage      Float          @default(1.0)
  
  // Aggregated values
  avg_entry_price Float        @default(0.0)
  avg_exit_price  Float?
  total_quantity  Float        @default(0.0)
  realized_pnl    Float        @default(0.0)
  total_fees      Float        @default(0.0)
  
  executions      Execution[]
  
  opened_at     DateTime       @default(now())
  closed_at     DateTime?
  updated_at    DateTime       @updatedAt

  @@index([user_id])
  @@index([status])
}

model Execution {
  id          Int      @id @default(autoincrement())
  position_id Int
  position    Position @relation(fields: [position_id], references: [id], onDelete: Cascade)
  
  type        String   // "ENTRY" or "EXIT"
  price       Float
  quantity    Float
  fees        Float    @default(0.0)
  executed_at DateTime @default(now())

  @@index([position_id])
}
